# Configurações da API Primecod
# URL da API de produtos
PRIMECOD_API_URL=https://api.primecod.app/api/catalog/products

# Token de autenticação fornecido pela Primecod
PRIMECOD_API_TOKEN=369|MrP5nbIaxH6qIXCtnrAeCRkCJO1bxWGqgUMM5BBZ84f76b16

# Tipo de autenticação (geralmente Bearer)
PRIMECOD_API_TOKEN_TYPE=Bearer

# Código de país para filtrar produtos (ex: es=España, pt=Portugal)
PRIMECOD_COUNTRY_CODE=es

# Quantidade de itens por página (máximo recomendado: 50)
PRIMECOD_PAGE_SIZE=12

# ===================================================================
# Banco de dados PostgreSQL
# ===================================================================
# Formato: postgresql://user:password@host:port/database
# Exemplo local: postgresql://postgres:password@localhost:5432/primecod
# Exemplo remoto: postgresql://user:pass@db.example.com:5432/primecod
DATABASE_URL=postgresql://user:password@localhost:5432/primecod
