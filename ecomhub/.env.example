# Credenciais de login do portal EcomHub
ECOMHUB_EMAIL=seu-email@exemplo.com
ECOMHUB_PASSWORD=sua-senha

# URLs (normalmente nao precisa alterar)
ECOMHUB_LOGIN_URL=https://go.ecomhub.app/login
ECOMHUB_PRODUCTS_URL=https://go.ecomhub.app/products
ECOMHUB_API_PREFIX=https://api.ecomhub.app/api/products
ECOMHUB_CATEGORIES_URL=https://api.ecomhub.app/api/productsCategories
# Endpoint de detalhe do produto ({URL}/{id}) usado para preencher a descricao
ECOMHUB_PRODUCT_URL=https://api.ecomhub.app/api/products
# Quantas requisicoes de detalhe rodam em paralelo ao buscar descricoes
ECOMHUB_DETAIL_CONCURRENCY=10

# Conexao com o PostgreSQL (usada pelo Prisma)
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL=postgresql://postgres:123456@localhost:5432/ecohub?schema=public

# Navegador: true = headless (sem janela), false = visivel (debug)
HEADLESS=true
