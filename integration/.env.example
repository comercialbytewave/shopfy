# Banco com a tabela unificada (mesma do unify_catalog.py).
# A tabela de comparacao shopify_sku_status e criada neste banco.
UNIFIED_DATABASE_URL=postgresql://postgres:123456@localhost:5432/unified_catalog

# --- Shopify (app custom: Settings > Apps > Develop apps > API credentials) ---
# Deixe VAZIO ate ter as credenciais (o sync ainda roda, marcando tudo como
# "nao cadastrado"; o envio fica desabilitado).
# Dominio da loja, no formato minha-loja.myshopify.com
SHOPIFY_STORE_DOMAIN=
# Admin API access token (comeca com shpat_...)
SHOPIFY_ACCESS_TOKEN=
# Versao da Admin API (GraphQL). Atual estavel: 2025-10.
SHOPIFY_API_VERSION=2025-10

# Status com que os produtos sao criados na Shopify: DRAFT (rascunho, seguro)
# ou ACTIVE (publicado na hora).
SHOPIFY_CREATE_STATUS=DRAFT

# Porta do servidor web local
PORT=5005

# --- Groq (traducao de descricoes via IA) ---
# Chave da API do Groq (https://console.groq.com/keys). Comeca com gsk_...
# Sem ela, o botao de traducao na listagem fica desabilitado.
GROQ_API_KEY=
# Modelo usado para traduzir (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
# Endpoint compativel com OpenAI (normalmente nao precisa alterar)
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
